# Server Configuration
PORT=3000
JWT_SECRET=your_jwt_secret_here
MEDIASOUP_MIN_PORT=10000
MEDIASOUP_MAX_PORT=11000
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=meet_clone
DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/meet_clone?schema=public

# Redis Configuration
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@localhost:6379

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# AI Service Configuration
DEEPL_API_KEY=your_deepl_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
AI_SOCKET_TOKEN=your_ai_socket_token
AI_ROOM_ID=your_room_id_for_ai_transcripts
SIGNALING_URL=http://localhost:3000
AI_RTP_PORT=5000
AI_SAMPLE_RATE=16000
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Frontend Configuration
VITE_API_URL=http://localhost:3000
